{
  "name": "fat-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next lint",
    "seed:admin": "node ensure_admin.js",
    "seed:employee": "node ensure_employee.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "npm run seed:admin",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.26.0",
    "mariadb": "^3.5.3",
    "next": "16.2.10",
    "next-auth": "^4.24.14",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.16",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "react-rnd": "^10.5.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "mammoth": "^1.12.0",
    "prisma": "^7.8.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
